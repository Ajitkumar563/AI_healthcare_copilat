# ─────────────────────────────────────────────────────────────────────────────
# Sahaay Backend — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (async driver).
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/healthcare_copilot

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
# Google AI Studio API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Random 32-char secret used to sign JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Email Alerts (optional) ───────────────────────────────────────────────────
# Used for emergency health alert emails when a critical report is detected.
# If either variable is missing the app works normally — emails are just skipped.
#
# Setup:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to myaccount.google.com → Security → App Passwords.
#   3. Create an App Password for "Mail" — copy the 16-character code.
#   4. Paste it as SMTP_APP_PASSWORD below (spaces are fine, they are stripped).
#
SMTP_EMAIL=your-gmail@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── WhatsApp — Meta Cloud API (optional, outbound report delivery) ────────────
# Used to send report summaries to patients via WhatsApp Cloud API.
# If either variable is missing, the button shows "not configured" — app works normally.
#
# Setup:
#   1. Go to developers.facebook.com → Create App → Add "WhatsApp" product.
#   2. In WhatsApp → Getting Started, copy the temporary access token and phone number ID.
#   3. Add up to 5 recipient numbers for testing (Settings → Manage phone number list).
#   4. For production, generate a permanent token via a System User in Meta Business Suite.
#
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# ── WhatsApp — Twilio Sandbox (optional, inbound AI webhook) ─────────────────
# Used for the two-way WhatsApp AI assistant (POST /api/whatsapp/webhook).
# Patients can WhatsApp the sandbox to query reports, reminders, or ask health Qs.
# If credentials are missing the webhook still runs — just skips validation + AI calls.
#
# Setup:
#   1. Sign up at twilio.com → Messaging → Try it out → Send a WhatsApp message.
#   2. Join the sandbox: send "join <word>-<word>" from your phone to +14155238886.
#   3. In sandbox settings set Webhook URL (HTTP POST):
#        https://<your-ngrok-or-domain>/api/whatsapp/webhook
#   4. Copy credentials below.  For local dev set WHATSAPP_SKIP_VALIDATION=true.
#
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX   # optional: pin to one number in sandbox
WHATSAPP_SKIP_VALIDATION=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── File Uploads ──────────────────────────────────────────────────────────────
# Where uploaded report files are stored (relative to backend root).
UPLOAD_DIR=uploads
